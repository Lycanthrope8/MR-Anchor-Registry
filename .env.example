# MR-Anchor-Registry Environment
FABRIC_VERSION=2.5.4
POSTGRES_VERSION=15-alpine
CURL_VERSION=8.5.0

FABRIC_CHANNEL=mychannel
FABRIC_CHAINCODE=anchorregistry
FABRIC_LOGGING_SPEC=INFO
FABRIC_MOCK=false

ORDERER_PORT=7050
ORDERER_ADMIN_PORT=7053
PEER_PORT=7051
PEER_CHAINCODE_PORT=7052

POSTGRES_PORT=5432
POSTGRES_DB=anchor_registry
POSTGRES_USER=anchor_admin
POSTGRES_PASSWORD=anchor_secret_2025

GATEWAY_PORT=3000
NODE_ENV=production
ENDORSEMENT_THRESHOLD=1

API_KEYS=proposer-key-001:proposer:Alice,endorser-key-001:endorser:Carlos,supervisor-key-001:supervisor:Eva
SUPERVISOR_IDS=supervisor-key-001

# Parley LLM
PARLEY_API_KEY=your_actual_key
PARLEY_BASE_URL=https://keys.theparley.org/v1
PARLEY_MODEL=gpt-5.2
DEFAULT_MODE=llm